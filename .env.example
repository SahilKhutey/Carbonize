# .env.example
# Copy this file to .env and fill in your own values
# DO NOT commit .env to version control

# === Database ===
POSTGRES_USER=cbms
POSTGRES_PASSWORD=__SET_ME__
POSTGRES_DB=cbms

# === Redis ===
REDIS_PASSWORD=__SET_ME__

# === S3 / MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=__SET_ME__
S3_BUCKET=cbms-reports
S3_ACCESS_KEY=__SET_ME__
S3_SECRET_KEY=__SET_ME__

# === Auth ===
JWT_SECRET=__SET_ME_GENERATE_RANDOM_64_CHARS__

# === Observability ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=__SET_ME__
